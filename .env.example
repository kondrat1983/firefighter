# Database Configuration
DATABASE_URL=postgresql://firefighter:password@localhost:5432/firefighter
POSTGRES_USER=firefighter
POSTGRES_PASSWORD=password
POSTGRES_DB=firefighter

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=your-secret-key-change-this-in-production

# External APIs
OPENAI_API_KEY=your-openai-api-key

# --- Reddit (asyncpraw) ---
# How to get:
#   1. Go to https://www.reddit.com/prefs/apps
#   2. Scroll down → "create another app"
#   3. Name: Firefighter  |  Type: "script"  |  Redirect URI: http://localhost
#   4. After creation, copy "client id" (under app name) and "secret"
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=Firefighter QA Bot v1.0 by /u/YOUR_REDDIT_USERNAME

# --- Steam ---
# Steam Reviews & App Details APIs are PUBLIC — no key required.
# STEAM_API_KEY is only needed if you want Valve's official Web API (achievements,
# player stats, etc.). Get one at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# --- Twitter / X (optional, requires paid plan) ---
# Free tier does NOT support reading/searching tweets.
# Basic plan ($100/mo): https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=

# Monitoring
LOG_LEVEL=INFO
SENTRY_DSN=optional-sentry-dsn

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000